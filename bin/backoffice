#!/bin/bash
# Back-office daemon launcher — runs in the mog-backoffice worktree
# Usage: bin/backoffice start [heartbeat_seconds]
#        bin/backoffice stop
#        bin/backoffice logs [-f]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
BACKOFFICE_DIR="$(cd "$PROJECT_DIR/../mog-backoffice" 2>/dev/null && pwd)" || {
    echo "Error: ../mog-backoffice worktree not found."
    echo "Create it with: git worktree add ../mog-backoffice backoffice"
    exit 1
}

LOOP_DIR="$BACKOFFICE_DIR/.loop-backoffice"
STATE_DIR="$LOOP_DIR/state"
LOG_DIR="$LOOP_DIR/logs"
PID_FILE="$STATE_DIR/daemon.pid"

cmd="${1:-help}"
shift 2>/dev/null || true

case "$cmd" in
    start)
        heartbeat="${1:-120}"
        echo "Starting back-office daemon in $BACKOFFICE_DIR"
        echo "  Loop dir: $LOOP_DIR"
        echo "  Heartbeat: ${heartbeat}s"

        # Copy .env if missing in worktree
        [ ! -f "$BACKOFFICE_DIR/.env" ] && [ -f "$PROJECT_DIR/.env" ] && {
            cp "$PROJECT_DIR/.env" "$BACKOFFICE_DIR/.env"
            echo "  Copied .env to worktree"
        }

        # Use the wrapper script that patches LOOP_DIR into daemon.sh
        export LOOP_DIR
        nohup bash "$BACKOFFICE_DIR/.loop-backoffice/daemon-wrapper.sh" "$BACKOFFICE_DIR" "$heartbeat" \
            >> "$LOG_DIR/daemon.log" 2>&1 &
        echo "  PID: $!"
        echo "$!" > "$PID_FILE"
        echo "  Logs: bin/backoffice logs -f"
        ;;

    stop)
        if [ -f "$PID_FILE" ]; then
            pid=$(cat "$PID_FILE")
            if kill -0 "$pid" 2>/dev/null; then
                kill "$pid"
                echo "Stopped back-office daemon (PID $pid)"
            else
                echo "PID $pid not running"
            fi
            rm -f "$PID_FILE"
        else
            echo "No PID file found"
        fi
        ;;

    logs)
        log_file="$LOG_DIR/daemon.log"
        if [ ! -f "$log_file" ]; then
            echo "No log file yet at $log_file"
            exit 0
        fi
        if [ "${1:-}" = "-f" ]; then
            tail -f "$log_file"
        else
            tail -50 "$log_file"
        fi
        ;;

    status)
        if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
            echo "Running (PID $(cat "$PID_FILE"))"
            echo "Worktree: $BACKOFFICE_DIR"
            echo "Branch: $(git -C "$BACKOFFICE_DIR" branch --show-current)"
            cat "$STATE_DIR/running.json" 2>/dev/null
        else
            echo "Not running"
        fi
        ;;

    *)
        echo "Usage: bin/backoffice {start [heartbeat]|stop|logs [-f]|status}"
        ;;
esac
